# Copy from repo root `.env.example`, or after `supabase start` run:
#   supabase status
# and set DATABASE_URL (DB URL), SUPABASE_URL (API URL), SUPABASE_JWT_SECRET, etc.

DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@127.0.0.1:54322/postgres
PORT=3000
API_PUBLIC_URL=http://localhost:3000
PUBLIC_WEB_URL=http://localhost:5173
PUBLIC_ADMIN_URL=http://localhost:5174
SUPABASE_URL=http://127.0.0.1:54321
# Local: SUPABASE_JWT_SECRET= copy JWT_SECRET from `supabase status -o env`
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Optional: hardcode admin by email (see root .env.example)
ADMIN_EMAIL=neil@blueprintapps.io

# Optional: [python-audio-separator](https://github.com/nomadkaraoke/python-audio-separator) — instrumental + acapella for original uploads
STEM_SEPARATION_ENABLED=true
AUDIO_SEPARATOR_PYTHON=/Users/neilbhargava/.pyenv/shims/python
STEM_SEPARATION_TIMEOUT_MS=1500000
# Legacy aliases still work: SPLEETER_ENABLED, SPLEETER_PYTHON, SPLEETER_TIMEOUT_MS
# Optional: AUDIO_SEPARATOR_MODEL, AUDIO_SEPARATOR_MODEL_DIR, AUDIO_SEPARATOR_CHUNK_DURATION
