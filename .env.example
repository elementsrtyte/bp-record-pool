# Local: start Supabase first — `pnpm supabase:start` — then run `supabase status`
# and copy **DB URL** → DATABASE_URL, **API URL** → SUPABASE_URL, **anon key**, **JWT secret**.
#
# Example shapes (your password/key will differ — always use `supabase status`):
DATABASE_URL=postgresql://postgres:local@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
# API auth — REQUIRED for local: copy JWT_SECRET from `supabase status -o env` (HS256 user sessions).
SUPABASE_JWT_SECRET=
# Optional: secret / service role key (`SERVICE_ROLE_KEY` or dashboard secret). getUser fallback.
SUPABASE_SERVICE_ROLE_KEY=

# API
PORT=3000
API_PUBLIC_URL=http://localhost:3000
LOCAL_UPLOAD_DIR=./uploads

# OpenAI — optional: admin “Generate cover (OpenAI)” for playlists (`POST /api/admin/playlists/:id/generate-artwork`)
OPENAI_API_KEY=
# Optional overrides: default model is dall-e-3. Examples: gpt-image-1-mini, gpt-image-1.5
OPENAI_IMAGE_MODEL=gpt-image-1-mini
OPENAI_IMAGE_QUALITY=standard
OPENAI_IMAGE_QUALITY_GPT=medium
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_TIMEOUT_MS=180000

# Admin API (`/api/admin/*`): if set, only this user (Supabase auth email) can upload / list. Case-insensitive.
# If unset, falls back to `profiles.role = 'admin'` in the database.
ADMIN_EMAIL=neil@blueprintapps.io

# CORS
PUBLIC_WEB_URL=http://localhost:5173
PUBLIC_ADMIN_URL=http://localhost:5174

# S3-compatible (optional; omit for local disk under apps/api/uploads)
# S3_BUCKET=
# S3_REGION=auto
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# PUBLIC_ASSET_BASE_URL=

# Stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=

# Frontends (apps/web + apps/admin .env):
# VITE_API_URL=http://localhost:3000
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=<anon key from supabase status>
