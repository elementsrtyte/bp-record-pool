{
  "name": "bp-record-pool",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n api,web,admin \"pnpm --filter @bp/api dev\" \"pnpm --filter @bp/web dev\" \"pnpm --filter @bp/admin dev\"",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "db:generate": "pnpm --filter @bp/api db:generate",
    "db:migrate": "pnpm --filter @bp/api db:migrate",
    "db:push": "pnpm --filter @bp/api db:push",
    "migrate-track-versions": "pnpm --filter @bp/api migrate-track-versions",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "bulk-upload": "node scripts/bulk-upload.mjs",
    "backfill-track-analysis": "pnpm --filter @bp/api backfill-track-analysis",
    "backfill-work-kind": "pnpm --filter @bp/api backfill-work-kind",
    "reset-catalog": "pnpm --filter @bp/api run reset-catalog --"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "music-metadata": "^11.12.3"
  },
  "packageManager": "pnpm@10.33.0"
}
